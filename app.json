{
  "expo": {
    "name": "Conduit AI",
    "slug": "conduit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "conduitai",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.conduitai.app",
      "buildNumber": "10",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID for quick and secure login"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "io.conduitai.app",
      "versionCode": 10
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0EA5E9"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a547e37-6e21-4587-99f3-39d13c5ad6a2"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "wpbluiss"
  }
}
