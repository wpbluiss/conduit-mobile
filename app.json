{
  "expo": {
    "name": "Praxis",
    "slug": "conduit-mobile",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "conduitai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.conduitai.app",
      "buildNumber": "17",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Praxis uses the microphone for voice mode so you can talk with Atlas and the team.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "package": "io.conduitai.app",
      "versionCode": 16
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#5B63E8"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a547e37-6e21-4587-99f3-39d13c5ad6a2"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "wpbluiss"
  }
}
